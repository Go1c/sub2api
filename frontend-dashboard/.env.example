# Dev server port (default 5174)
VITE_DEV_PORT=5174

# Backend base URL. Leave empty to use built-in mock adapter.
# Example: http://localhost:8080
VITE_API_BASE_URL=

# Set to "false" to turn off the mock axios interceptor even without a backend.
VITE_USE_MOCK=true

# Visible site name shown in the top bar.
VITE_SITE_NAME=Dragon Code
